{
  "name": "@teriac/api",
  "version": "0.0.0",
  "private": true,
  "description": "Teriac NestJS API",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:introspect": "drizzle-kit introspect && bash scripts/post-introspect.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bash scripts/run-migrations.sh",
    "db:migrate:status": "bash scripts/run-migrations.sh --status",
    "db:migrate:dry": "bash scripts/run-migrations.sh --dry-run",
    "db:seed-dev-user": "tsx scripts/seed-dev-user.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.0.7",
    "@teriac/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "helmet": "^8.0.0",
    "mysql2": "^3.11.5",
    "nestjs-cls": "^4.5.0",
    "nestjs-i18n": "^10.5.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@teriac/config": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.1",
    "typescript": "~5.6.3",
    "vitest": "^2.1.8"
  }
}
