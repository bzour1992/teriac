{
  "extends": "@teriac/config/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@db/*": ["drizzle/*"]
    },
    "resolveJsonModule": true,
    "strictPropertyInitialization": false
  },
  "include": ["src/**/*", "drizzle/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
