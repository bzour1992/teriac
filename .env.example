# =============================================================================
# Teriac — root .env example
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# ---- API server ----
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ---- Database (MariaDB) ----
# Pointed at your existing staging copy of the legacy DB.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=okkeh
DB_CONNECTION_LIMIT=10

# ---- Auth ----
# Phase 0: built-in JWT + bcrypt. Swap for Keycloak issuer URL when ready.
JWT_SECRET=change-me-in-production-use-a-64char-hex-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-in-production-different-from-the-other
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ---- File storage (Phase 0: local disk) ----
UPLOAD_DIR=./apps/api/uploads
MAX_UPLOAD_MB=20

# ---- Tenant defaults for local dev ----
# Staging DB has a single HCenter. Paste its HCenterID here to skip the login step
# during early development. Remove once real auth is wired.
DEV_DEFAULT_HCENTER_ID=
DEV_DEFAULT_USER_ID=

# ---- CORS ----
WEB_ORIGIN=http://localhost:5173

# ---- Web app (Vite) ----
# Vite only exposes vars prefixed with VITE_ to the client bundle.
VITE_API_BASE_URL=http://localhost:3001/v1
VITE_DEFAULT_LOCALE=en
